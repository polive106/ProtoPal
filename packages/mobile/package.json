{
  "name": "@acme/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "build": "echo 'Mobile build requires expo prebuild — use dev for local development'",
    "prebuild": "expo prebuild --platform android --no-install",
    "build:android": "cd android && ./gradlew assembleDebug",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@acme/design-system-mobile": "workspace:*",
    "@acme/i18n": "workspace:*",
    "@acme/shared": "workspace:*",
    "@babel/runtime": "^7.29.2",
    "@expo-google-fonts/karla": "^0.4.2",
    "@expo-google-fonts/source-serif-4": "^0.4.1",
    "@expo/metro-runtime": "^6.1.2",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.97.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "^55.0.6",
    "expo-linking": "~8.0.11",
    "expo-localization": "^55.0.13",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "^55.0.17",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.1.23",
    "react": "19.2.5",
